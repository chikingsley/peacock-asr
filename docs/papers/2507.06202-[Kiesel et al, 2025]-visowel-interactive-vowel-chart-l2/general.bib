@article{almusharraf_efl_2022,
	title = {{EFL} learners’ confidence, attitudes, and practice towards learning pronunciation},
	volume = {32},
	rights = {© 2021 John Wiley \& Sons Ltd.},
	issn = {1473-4192},
	url = {https://onlinelibrary.wiley.com/doi/abs/10.1111/ijal.12408},
	doi = {10.1111/ijal.12408},
	abstract = {Although pronunciation is part of the curriculum in many {EFL} education programs, it is often neglected in instruction. The study's rationale was to fill the literature gap and explore Saudi {EFL} learners’ confidence, attitudes, and practice towards learning pronunciation. To this end, the study recruited a convenience sample of 336 Saudi {EFL} learners majoring in English at a university in Saudi Arabia. Statistical analyses were conducted to determine: (i) learners’ pronunciation confidence level; (ii) whether enrollment in phonetic courses, travel to English-speaking countries, and attitudes towards pronunciation affected learners’ confidence in their pronunciation; and (iii) learners’ reported pronunciation attitudes and practices. It was found that learners in this study have higher than neutral confidence in their pronunciation and hold a highly positive attitude towards English native-like pronunciation. Interestingly, this study showed no statistically significant difference between those who had taken a phonetic(s) course and those who had not in terms of their confidence in their pronunciation. Therefore, this study urges instructors be aware of their learners’ needs in pronunciation, present appropriate materials, and further opportunities to practice various strategies.},
	pages = {126--141},
	number = {1},
	journaltitle = {International Journal of Applied Linguistics},
	author = {Almusharraf, Asma},
	urldate = {2025-01-20},
	date = {2022},
	langid = {english},
	note = {\_eprint: https://onlinelibrary.wiley.com/doi/pdf/10.1111/ijal.12408},
	keywords = {bilingual teaching, English as a foreign language ({EFL}), English pronunciation, learners’ beliefs, pronunciation teaching, second language acquisition ({SLA})},
	file = {Full Text PDF:/home/charcknado/Zotero/storage/YVCE7SMJ/Almusharraf - 2022 - EFL learners’ confidence, attitudes, and practice towards learning pronunciation.pdf:application/pdf},
}

