\usepackage[bottom]{footmisc} % always place footer at bottom of page 



% Page geometry
\geometry{letterpaper, margin=1in}

% Ensure \shorttitle exists (fallback to \title after it's known)
\makeatletter
\providecommand{\shorttitle}{}%
\AtBeginDocument{%
  \ifx\shorttitle\@empty
    \gdef\shorttitle{\@title}%
  \fi
}
\makeatother

% Spacing
\setlength{\headheight}{16pt}
\setlength{\headsep}{18pt}

% ===== Footer spacing controls (place after \RequirePackage{fancyhdr}) =====

% 1) Space from main text area down to the footer baseline
\setlength{\footskip}{28pt}  % (default ~20pt)

% 2) Draw a foot rule and control the vertical gaps above/below it
\renewcommand{\footrulewidth}{0.4pt}
\renewcommand{\footrule}{%
  \vspace{16pt}% gap between main text and the rule
  \hrule width\headwidth height\footrulewidth
  \vspace{8pt}% gap between rule and the footer text
}

% % 3) (Only if you use actual \footnote{...} in body text)
% %    Increase the space above the footnote block and between footnotes
% \setlength{\skip\footins}{16pt plus 2pt minus 2pt} % gap above true footnotes
% \setlength{\footnotesep}{10pt}                     % space between footnotes


% Draw footer line
\renewcommand{\footrulewidth}{0.4pt}


% ========================
% Subsequent pages: header with title only
% ========================
\fancypagestyle{liquidheader}{
  \fancyhf{} % clear everything

  % ----- Header -----
  \fancyhead[L]{\textbf{\shorttitle}}

  % ----- Footer -----
  % \fancyfoot[L]{Correspondence to \texttt{mathias@liquid.ai}}
  \fancyfoot[R]{\thepage}

  \renewcommand{\headrulewidth}{0.4pt}
}


% ========================
% First page: header with logo + title
% ========================
\fancypagestyle{plain}{
  \fancyhf{} % clear everything

  % ----- Header -----
  \fancyhead[L]{%
    \raisebox{-.1\height}{\includegraphics[height=0.7cm]{images/logo_liquid.png}}%
    \hspace{0.6em}\textbf{\shorttitle}
  }

  % ----- Footer -----
  % \fancyfoot[C]{Please cite this work as “Liquid AI (2025)". See Contributions section for the full author list.}
  \fancyfoot[R]{\thepage}

  \renewcommand{\headrulewidth}{0.4pt}
}

% Apply to all pages by default
\pagestyle{liquidheader}

% Abstract box environment
\newtcolorbox{abstractbox}{
  colback=liquidpurple!10,
  colframe=liquidpurple!40,
  boxrule=0pt,
  arc=4mm,
  left=5mm, right=5mm, top=3mm, bottom=3mm
}

% Hyperlink colors
\hypersetup{
  colorlinks=true,
  linkcolor=liquidpurple,
  urlcolor=liquidpurple,
  citecolor=liquidpurple
}

